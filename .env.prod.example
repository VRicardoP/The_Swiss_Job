# ---------------------------------------------------------------------------
# SwissJobHunter — Plantilla de entorno de producción
# ---------------------------------------------------------------------------
# Copia este fichero a `.env.prod` y rellena los CHANGE_ME. NUNCA committees el
# .env.prod resultante (ya está en .gitignore via patrón .env*).
# ---------------------------------------------------------------------------

# === Database ====================================================
POSTGRES_USER=swissjob
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=swissjobhunter

# Mantener consistente con POSTGRES_PASSWORD de arriba
DATABASE_URL=postgresql+asyncpg://swissjob:__CHANGE_ME__@postgres:5432/swissjobhunter

# === Redis =======================================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === Secrets de la aplicación ====================================
# OBLIGATORIO cambiar. El backend aborta el arranque si conserva el default.
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=__CHANGE_ME__

# === API keys externas ===========================================
# OBLIGATORIO si quieres re-ranking LLM, traducción de títulos, doc generator
GROQ_API_KEY=__YOUR_GROQ_KEY__

# Opcionales — providers de empleo que requieren key. Dejar vacío para
# desactivar ese provider sin tocar nada más.
JSEARCH_RAPIDAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
CAREERJET_AFFID=

# === CORS ========================================================
# JSON-array literal. Pydantic lo parsea como list[str].
# Incluye el hostname Tailscale del NAS por el que se accede al frontend.
BACKEND_CORS_ORIGINS=["http://capsule.tailebc81d.ts.net:8080"]

# === Scheduler ===================================================
SCHEDULER_ENABLED=True
# Cosecha diaria autónoma (fetch → embeddings → dedup → matching) UNA vez al día
# a hora VARIABLE (patrón circadiano). True = sustituye al fetch por intervalos y
# todo corre sin intervención del usuario. HOUR = base CET; JITTER = ±N horas.
SCHEDULER_DAILY_HARVEST_ENABLED=True
SCHEDULER_DAILY_HARVEST_HOUR=12
SCHEDULER_DAILY_HARVEST_JITTER_HOURS=4

# Google Gemini — proveedor primario de generación de documentos (free tier) y
# FALLBACK del re-ranking del matching (resiliencia si Groq caduca/satura).
# Vacío = solo Groq. Modelo: GEMINI_MODEL (gemini-2.5-flash)
GEMINI_API_KEY=

# === Email (SMTP) para avisos ===
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, y una App Password (16 car.,
# requiere 2FA) como SMTP_PASSWORD. Vacío = avisos desactivados.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=True

# === Alerta: ofertas de profesor de primaria (colegios suizos) → email ===
TEACHER_ALERT_ENABLED=True
TEACHER_ALERT_EMAIL=amoore3199@gmail.com
