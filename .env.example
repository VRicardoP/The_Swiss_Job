# ── PostgreSQL ──────────────────────────────────────
POSTGRES_USER=swissjob
POSTGRES_PASSWORD=swissjob_dev_2024
POSTGRES_DB=swissjobhunter
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://swissjob:swissjob_dev_2024@postgres:5432/swissjobhunter

# ── Redis ──────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── Celery ─────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Backend ────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:5174","http://localhost:5173"]
SECRET_KEY=change-me-in-production

# ── JWT ───────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Provider API Keys ─────────────────────────────
JSEARCH_RAPIDAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
CAREERJET_AFFID=

# ── Host ports (docker-compose) ───────────────────
HOST_POSTGRES_PORT=5435
HOST_REDIS_PORT=6380
HOST_BACKEND_PORT=8002
HOST_FRONTEND_PORT=5174

# ── Scheduler ─────────────────────────────────────
SCHEDULER_ENABLED=True
# Cosecha diaria autónoma (fetch → embeddings → dedup → matching) UNA vez al día
# a hora VARIABLE (patrón circadiano). True = sustituye al fetch por intervalos.
SCHEDULER_DAILY_HARVEST_ENABLED=True
SCHEDULER_DAILY_HARVEST_HOUR=12
SCHEDULER_DAILY_HARVEST_JITTER_HOURS=4

# Google Gemini — proveedor primario de generación de documentos (free tier) y
# FALLBACK del re-ranking del matching (resiliencia si Groq caduca/satura).
# Vacío = solo Groq. Modelo: GEMINI_MODEL (gemini-2.5-flash)
GEMINI_API_KEY=

# === Email (SMTP) para avisos ===
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, y una App Password (16 car.,
# requiere 2FA) como SMTP_PASSWORD. Vacío = avisos desactivados.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=True

# === Alerta: ofertas de profesor de primaria (colegios suizos) → email ===
TEACHER_ALERT_ENABLED=True
TEACHER_ALERT_EMAIL=amoore3199@gmail.com
